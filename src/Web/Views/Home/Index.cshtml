@using Web.Domain
@model IndexModel
@{
    ViewData["Title"] = "MODARG";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<main class="home-page">
    <div class="container py-5">
        <!-- DESTACADOS -->
        <section class="mb-5">
            <div class="section-header mb-4">
                <h2 class="section-title">
                    DESTACADOS
                </h2>
            </div>
            <div class="row g-4">
                @foreach (var p in Model.ProductosDestacados)
                {
                    <div class="col-12 col-md-6 col-lg-3">
                        <a asp-controller="Productos" asp-action="Detalle" asp-route-id="@p.Id"
                               class="text-decoration-none text-dark">
                            <article class="product-card">
                                <img src="@p.UrlImagen" alt="@p.Nombre" class="img-fluid product-image" />
                                <div class="product-body">
                                    <h3 class="product-title">
                                        @p.Nombre
                                    </h3>
                                </div>
                            </article>
                        </a>
                    </div>
                }
            </div>
        </section>
        <!-- CATEGORIAS -->
        <section>
            <div class="section-header mb-4">
                <h2 class="section-title">
                    CATEGORIAS
                </h2>
            </div>
            <div class="row g-4">
                @foreach (var p in Model.Categorias)
                {
                    <div class="col-12 col-md-6 col-lg-3">
                        <a asp-controller="Productos" asp-action="Index" asp-route-categoriaId="@p.Id"
                               class="text-decoration-none text-dark">
                            <article class="category-card">
                                <img src="@p.Url" alt="@p.Nombre" class="img-fluid product-image" />
                                <div class="category-body">
                                    <h3 class="category-title">
                                        @p.Nombre
                                    </h3>
                                </div>
                            </article>
                        </a>
                    </div>
                }
            </section>
        </div>
    </main>
