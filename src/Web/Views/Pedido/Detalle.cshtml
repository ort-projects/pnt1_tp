@model IEnumerable<PedidoItemViewModel>

@{
    ViewData["Title"] = "Detalle del pedido";

    var total = Model?.Sum(x => x.Subtotal) ?? 0;
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Detalle del pedido</h4>
        </div>

        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info mb-0">
                    El pedido no tiene productos cargados.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Producto</th>
                                <th>SKU</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio unitario</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.NombreProducto</td>
                                    <td>@item.SKU</td>
                                    <td class="text-center">@item.Cantidad</td>
                                    <td class="text-end">
                                        @item.PrecioUnitario.ToString("C2")
                                    </td>
                                    <td class="text-end">
                                        @item.Subtotal.ToString("C2")
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-end">Total</th>
                                <th class="text-end">
                                    @total.ToString("C2")
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a href="/pedido" class="btn btn-secondary">
            Volver
        </a>
    </div>
</div>