@model Web.Models.ProductoModel
@{ ViewData["Title"] = Model.Nombre; }

@section Styles {
    <link rel="stylesheet" href="~/css/prod.css" />
    <link rel="stylesheet" href="~/css/prod-detalle.css" asp-append-version="true" />
}

<div class="detalle-page py-4">

    <!-- BACK -->
    <div class="mb-4">
        <a asp-action="Index" class="detalle-volver">
            <i class="bi bi-arrow-left"></i>
            Volver a productos
        </a>
    </div>

    <div class="row gx-5 gy-4 align-items-start">

        <!-- IMAGE -->
        <div class="col-12 col-md-6">
            <div class="detalle-img-wrapper">
                @if (!string.IsNullOrEmpty(Model.UrlImagen))
                {
                    <img src="@Model.UrlImagen" alt="@Model.Nombre" class="detalle-img" />
                }
                else
                {
                    <div class="detalle-img-placeholder">
                        <i class="bi bi-image"></i>
                    </div>
                }
            </div>
        </div>

        <!-- INFO -->
        <div class="col-12 col-md-6">
            <div class="detalle-info">

                <!-- SKU -->
                <span class="detalle-sku">SKU: @Model.SKU</span>

                <!-- NAME -->
                <h1 class="detalle-nombre">@Model.Nombre</h1>

                <!-- PRICE -->
                <p class="detalle-precio">$@Model.Precio.ToString("N2")</p>

                <!-- DIVIDER -->
                <hr class="detalle-divider" />

                <!-- DESCRIPTION -->
                @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
                {
                    <div>
                        <p class="detalle-label">Descripción</p>
                        <p class="detalle-descripcion">@Model.Descripcion</p>
                    </div>
                }

                <!-- ADD TO CART FORM -->
                <form asp-controller="Carrito" asp-action="Agregar" method="post">
                    <input type="hidden" name="productoId" value="@Model.Id" />

                    <div class="detalle-cantidad-section">
                        <label for="cantidad" class="detalle-label">Cantidad</label>
                        <input type="number" id="cantidad" name="cantidad"
                               value="1" min="1" max="99"
                               class="detalle-cantidad-input" />
                    </div>

                    <button type="submit" class="detalle-add-btn">
                        <i class="bi bi-cart3 me-2"></i>
                        Agregar al carrito
                    </button>
                </form>

            </div>
        </div>

    </div>

</div>
