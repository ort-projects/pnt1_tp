<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MODARG</title>
    
    <!-- GOOGLE FONTS -->

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
    href="https://fonts.googleapis.com/css2?family=Intel+One+Mono:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- CSS propio -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

</head>

<body>

    <!-- NAVBAR -->
    <header>

        <nav class="navbar navbar-expand-lg navbar-custom px-3 px-lg-4 py-3">

            <div class="container-fluid navbar-box">

                <!-- LOGO -->
                <a class="navbar-brand d-flex align-items-center gap-3" asp-controller="Home" asp-action="Index">

                    <img src="~/img/logo/logo.png" alt="Logo MODARG" class="logo-img">

                    <span class="logo-text">
                        MODARG
                    </span>

                </a>
                <!-- SEARCH -->
                <form class="d-flex flex-grow-1 mx-3 mx-lg-4" method="get" action="/productos/index" >


                    <input class="form-control search-input" type="search" placeholder="Buscar productos" name="search">

                </form>

                <!-- CART -->
                <a href="#" class="cart-link">

                    <i class="bi bi-cart3"></i>

                </a>

            </div>

        </nav>

    </header>

    <!-- MAIN -->
    <main class="container py-4 flex-grow-1">

        @RenderBody()

    </main>

    <!-- FOOTER -->
    <footer class="footer-custom px-3 px-lg-4 pb-4">

        <div class="footer-box">

            <!-- SOCIALS -->
            <div class="d-flex gap-4">

                <a href="#" class="footer-link">
                    Instagram
                </a>

                <a href="#" class="footer-link">
                    Facebook
                </a>

                <a href="#" class="footer-link">
                    TikTok
                </a>

            </div>

            <!-- COPYRIGHT -->
            <p class="footer-text mb-0">

                © 2026 MODARG

            </p>

        </div>

    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>