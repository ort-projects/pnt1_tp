<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web.styles.css" asp-append-version="true" />
</head>

<body>
    <header>

        <nav class="navbar navbar-expand-lg navbar-custom">

            <div class="container-fluid">

                <a class="navbar-brand d-flex align-items-center gap-3" asp-area="" asp-controller="Home"
                   asp-action="Index">

                    <img src="~/img/logo.png" alt="Logo" class="logo-img">

                    <span class="logo-text">
                        MODARG
                    </span>

                </a>

                <form class="d-flex flex-grow-1 justify-content-center mx-4" role="search" method="get" action="/productos/index">
                    <input class="form-control search-input" type="search" placeholder="Buscar" name="search">
                </form>

                <div class="cart-container">

                    <a href="#" class="cart-link">
                        <i class="bi bi-cart3"></i>
                    </a>

                </div>

            </div>

        </nav>

    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

  <footer class="footer-custom">
    <div class="footer-container">
        <div class="footer-socials">
            <a href="#" class="footer-link">Instagram</a>
            <a href="#" class="footer-link">Facebook</a>
            <a href="#" class="footer-link">TikTok</a>
        </div> <!-- Cerrar socials  -->
        
        <p class="footer-text">© 2026 MODARG</p>
    </div> <!-- Cerrar container -->
</footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
