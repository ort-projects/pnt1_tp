@{
    ViewData["Title"] = "Home Admin Page";
}
@model IEnumerable<ProductoModelAdmin>
@{
    Layout = "_LayoutAdmin";
}
<div class="text-center">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>SKU</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var producto in Model)
            {
                <tr>
                    <td>@producto.Nombre</td>
                    <td>@producto.NombreCategoria</td>
                    <td>@producto.SKU</td>

                    <td class="text-end">
                        <a href="/productos/edit/@producto.Id" class="btn btn-sm btn-outline-primary">
                            Editar
                        </a>

                        <form method="post" action="/productos/delete/@producto.Id" class="d-inline">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('¿Seguro que querés eliminar este producto?');">
                                Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
