@{
    ViewData["Title"] = "Home Admin Page";
}
@model IEnumerable<ProductoModelAdmin>
@{
    Layout = "_LayoutAdmin";
}

@section Styles {

    <link rel="stylesheet" href="~/css/admin-productos.css" asp-append-version="true" />

}
<h1 class="admin-productos-title mb-4"> Gestion de Productos </h1>
<div class="admin-actions mb-4 d-flex">
    <div>
        <a href="/Productos/New" class="admin-add-btn"><i class="bi bi-plus-lg"></i> Agregar Producto
        </a>
    </div>
    <div>
        <a href="/Productos/New" class="admin-add-btn"><i class="bi bi-cart"></i> Pedidos
        </a>
    </div>
</div>
<div class="admin-productos-page">
    <div class="table-responsive admin-productos-table">

        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>SKU</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var producto in Model)
                {
                    <tr>
                        <td>@producto.Nombre</td>
                        <td>@producto.NombreCategoria</td>
                        <td>@producto.SKU</td>

                        <td class="text-end">
                            <a href="/productos/edit/@producto.Id" class="btn btn-sm btn-outline-primary">
                                Editar
                            </a>

                            <form method="post" action="/productos/delete/@producto.Id" class="d-inline">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('¿Seguro que querés eliminar este producto?');">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

